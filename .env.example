# 前端本地開發用環境變數範本（複製為 .env.local 後修改）
# VITE_* 前綴的變數會暴露給瀏覽器端，請勿存放敏感金鑰

# --- 凌越 ERP SOAP/WCF 探測（scripts/ly_erp_probe.py）---
# 複製本檔為 .env 後填入；勿加 VITE_ 前綴，勿提交 .env
# LY_ERP_BASE_URL=http://192.168.0.10/ERPAPI
# LY_ERP_SOAP_URL=http://192.168.0.10/ERPAPI/ErpService.svc
# LY_ERP_COMPANY_CODE=01
# LY_ERP_USER=your_api_user
# LY_ERP_PASSWORD=your_api_password
# LY_ERP_DATA_KIND=000000
# LY_ERP_FETCH_LIMIT=5
# LY_ERP_FIELDS=SK_NO,SK_NAME,SK_UNIT,SK_SPEC
# LY_ERP_TARGET_NS=http://tempuri.org/
# LY_ERP_SOAP_INTERFACE=IErpService

# --- PostgreSQL + 外掛帳號（backend FastAPI）---
# DATABASE_URL=postgresql+asyncpg://erp:erp@localhost:5432/erp_assistant
# JWT_SECRET=請用 openssl rand -hex 32 產生
# JWT_EXPIRE_MINUTES=480
# ADMIN_INITIAL_USERNAME=admin
# ADMIN_INITIAL_PASSWORD=請設定至少 8 碼
# ADMIN_INITIAL_DISPLAY_NAME=系統管理員
