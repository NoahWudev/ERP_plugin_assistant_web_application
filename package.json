{
  "name": "erp-assistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "cd backend && uv run uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "cd backend && uv run alembic upgrade head",
    "db:seed": "cd backend && uv run python ../scripts/seed_admin.py",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "prepare:template": "node scripts/prepare-quotation-template.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "buffer": "^6.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "xlsx": "^0.18.5",
    "xlsx-populate": "^1.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
